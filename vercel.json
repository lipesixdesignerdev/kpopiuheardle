{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/songs/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=31536000",
        "Accept-Ranges": "bytes"
      },
      "dest": "/songs/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
